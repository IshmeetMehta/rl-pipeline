import re
import uuid
import logging
import asyncio
import shutil
import uvicorn
import time
from pathlib import Path
from fastapi import FastAPI, Body

# ==============================================================================
# 1. CONFIGURATION & LOGGING
# ==============================================================================
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger("go-reward-server")

app = FastAPI(title="Go Reward Server v3.1 (Bug Fixes & Decoding Safety)")

# ==============================================================================
# 2. UTILITY FUNCTIONS
# ==============================================================================

def clean_code(text: str) -> str:
    """
    Robust code extraction and package normalization.
    Ensures model-provided scripts don't conflict with our test runner.
    """
    if not text:
        return ""

    # Robust Markdown Extraction
    match = re.search(r"```(?:go)?\n?(.*?)```", text, re.DOTALL)
    if match:
        code = match.group(1).strip()
    else:
        code = text.strip()

    # Robust main() Stripping: Handles various spacing and brace placements
    code = re.sub(r'func\s+main\s*\(\s*\)\s*\{[\s\S]*?\}', '', code)
    
    # Package Normalization
    if code and not re.search(r'^\s*package\s+', code, re.MULTILINE):
        code = "package main\n\n" + code
        
    return code.strip()

async def run_command(command, cwd: Path, timeout=10):
    """
    Asynchronous execution engine with a precise watchdog timer.
    Includes decoding safety and aggressive process management to prevent FD leaks.
    """
    start_time = time.time()
    process = None
    try:
        process = await asyncio.create_subprocess_exec(
            *command,
            cwd=str(cwd),
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE
        )
        try:
            stdout_data, stderr_data = await asyncio.wait_for(process.communicate(), timeout=timeout)
            elapsed = time.time() - start_time
            return (
                process.returncode, 
                stdout_data.decode('utf-8', errors='replace'), 
                stderr_data.decode('utf-8', errors='replace'), 
                elapsed
            )
        except asyncio.TimeoutError:
            # Watchdog: Aggressively terminate/kill to free FDs and prevent zombies
            if process:
                try:
                    process.terminate()
                    await asyncio.sleep(0.1)
                    if process.returncode is None:
                        process.kill()
                except:
                    pass
                await process.wait()
            elapsed = time.time() - start_time
            return 124, "", "Execution Timeout (Watchdog Triggered)", elapsed
    except Exception as e:
        elapsed = time.time() - start_time
        return 1, "", str(e), elapsed
    finally:
        # Final safety check to ensure process is reaped
        if process and process.returncode is None:
            try:
                process.kill()
                await process.wait()
            except:
                pass

# ==============================================================================
# 3. VERIFICATION ENDPOINT
# ==============================================================================

@app.post("/verify")
async def verify_code(payload: dict = Body(...)):
    full_start_time = time.time()
    job_id = str(uuid.uuid4())[:8]
    raw_response = payload.get("response", "")
    extra_info = payload.get("extra_env_info", {})
    test_code = extra_info.get("test_code", "")
    
    logger.info(f"[JOB {job_id}] Processing verification request (Raw length: {len(raw_response)})")

    code = clean_code(raw_response)
    
    if not code:
        logger.warning(f"[JOB {job_id}] REWARD: -1.0 | REASON: No valid code blocks found.")
        return {"reward": -1.0, "log": "Empty or invalid code format"}

    work_dir = Path("/tmp") / f"go_job_{job_id}_{int(time.time())}"
    work_dir.mkdir(parents=True, exist_ok=True)
    
    try:
        # File Preparation
        (work_dir / "main.go").write_text(code)
        if test_code:
            if "package " not in test_code:
                test_code = "package main\n\n" + test_code
            (work_dir / "main_test.go").write_text(test_code)

        # 1. Module Setup
        await run_command(["go", "mod", "init", f"verify/job_{job_id}"], cwd=work_dir)
        
        # 2. Compilation
        logger.info(f"[JOB {job_id}] Compiling Go code...")
        exit_code, stdout, stderr, build_time = await run_command(["go", "build", "."], cwd=work_dir)
        
        if exit_code != 0:
            logger.info(f"[JOB {job_id}] REWARD: 0.1 | REASON: Compilation Failed | TIME: {build_time:.2f}s")
            return {"reward": 0.1, "log": f"Compilation Error: {stderr or stdout}"}

        # 3. Test Execution
        logger.info(f"[JOB {job_id}] Compilation successful. Running test suite...")
        t_exit, t_stdout, t_stderr, t_time = await run_command(["go", "test", "-v", "."], cwd=work_dir)
        
        total_time = time.time() - full_start_time

        if t_exit == 0:
            logger.info(f"[JOB {job_id}] REWARD: 1.0 | REASON: Success | EXEC: {t_time:.2f}s | TOTAL: {total_time:.2f}s")
            return {"reward": 1.0, "log": "Success"}
        elif t_exit == 124:
            logger.warning(f"[JOB {job_id}] REWARD: 0.0 | REASON: Watchdog Timeout | EXEC: {t_time:.2f}s")
            return {"reward": 0.0, "log": "Execution Timeout"}
        else:
            logger.info(f"[JOB {job_id}] REWARD: 0.3 | REASON: Test Failures | EXEC: {t_time:.2f}s")
            return {"reward": 0.3, "log": f"Test failures:\n{t_stdout}"}

    except Exception as e:
        logger.error(f"[JOB {job_id}] CRITICAL ERROR: {str(e)}")
        return {"reward": 0.0, "log": f"Internal server error: {str(e)}"}

    finally:
        # Post-process cleanup
        if work_dir.exists():
            shutil.rmtree(work_dir, ignore_errors=True)

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=8000)