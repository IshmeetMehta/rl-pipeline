import re
import uuid
import logging
import asyncio
import shutil
import uvicorn
import time
from pathlib import Path
from typing import Tuple, Dict, Any
from fastapi import FastAPI, Body
from pydantic import BaseModel, Field

# ==============================================================================
# 1. PRODUCTION CONFIGURATION & LOGGING
# ==============================================================================
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger("go-reward-server")

app = FastAPI(
    title="NemoRL Go Reward Server v4.0",
    description="High-performance asynchronous verification for Go code generation."
)

# ==============================================================================
# 2. DATA MODELS
# ==============================================================================

class VerificationRequest(BaseModel):
    response: str = Field(..., description="The raw string response from the LLM")
    extra_env_info: Dict[str, Any] = Field(
        default_factory=dict, 
        description="Metadata containing the 'test_code' to run against the solution"
    )

class VerificationResponse(BaseModel):
    reward: float
    log: str
    metrics: Dict[str, float]

# ==============================================================================
# 3. UTILITY FUNCTIONS
# ==============================================================================

def clean_code(text: str, target_package: str = "main") -> str:
    """
    Robust code extraction and package normalization.
    Ensures model-provided scripts don't conflict with our test runner.
    """
    if not text:
        return ""

    # 1. Robust Markdown Extraction
    # We construct the backticks programmatically to prevent UI truncation
    backticks = "`" * 3
    pattern = backticks + r"(?:go)?\n?(.*?)" + backticks
    
    match = re.search(pattern, text, re.DOTALL)
    if match:
        code = match.group(1).strip()
    else:
        code = text.strip()

    if not code:
        return ""

    # 2. Prevent Redeclaration Errors
    # Strip existing package declaration at the start of the string
    code = re.sub(r"^\s*package\s+\w+", "", code, count=1).strip()
    
    # Remove 'func main()' block
    # [\s\S]*? handles multi-line function bodies reliably.
    code = re.sub(r'func\s+main\s*\(\s*\)\s*\{[\s\S]*?\}', '', code).strip()

    # 3. Final Assembly
    # Re-insert a standardized package header to ensure namespace visibility for tests
    return f"package {target_package}\n\n{code}"

async def run_command(command: list, cwd: Path, timeout: int = 15) -> Tuple[int, str, str, float]:
    """
    Asynchronous execution engine with a precise watchdog timer.
    Includes decoding safety (errors='replace') and graceful process termination.
    Returns (exit_code, stdout, stderr, elapsed_time).
    """
    start_time = time.time()
    process = None
    try:
        process = await asyncio.create_subprocess_exec(
            *command,
            cwd=str(cwd),
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE
        )
        try:
            # wait_for raises asyncio.TimeoutError when the process hangs
            stdout, stderr = await asyncio.wait_for(process.communicate(), timeout=timeout)
            elapsed = time.time() - start_time
            # Safety: replace non-UTF-8 characters to prevent crashes on binary/noisy logs
            return (
                process.returncode or 0, 
                stdout.decode('utf-8', errors='replace').strip(), 
                stderr.decode('utf-8', errors='replace').strip(), 
                elapsed
            )
        except asyncio.TimeoutError:
            # Graceful shutdown sequence during timeout to avoid zombie processes
            try:
                if process:
                    process.terminate()
                    await asyncio.sleep(0.1)
                    if process.returncode is None:
                        process.kill()
            except Exception:
                pass
            
            # CRITICAL FIX FOR FD LEAKS (Errno 24):
            # When wait_for times out, the communicate() task is cancelled, leaving pipes open.
            # We MUST call communicate() again after killing the process to drain pipes and close FDs!
            if process:
                await process.communicate()
                
            elapsed = time.time() - start_time
            return 124, "", "Execution Timeout (Watchdog Triggered)", elapsed
            
    except Exception as e:
        elapsed = time.time() - start_time
        return 1, "", str(e), elapsed

# ==============================================================================
# 4. VERIFICATION PIPELINE
# ==============================================================================

@app.post("/verify", response_model=VerificationResponse)
async def verify_code(payload: VerificationRequest):
    """
    Main verification endpoint.
    Processes Go code in a sandboxed, unique environment with Tiered Rewards and 
    precise performance tracking.
    """
    full_start_time = time.time()
    job_id = str(uuid.uuid4())[:8]
    raw_response = payload.response
    test_code = payload.extra_env_info.get("test_code", "")
    
    logger.info(f"[JOB {job_id}] Received verification request (Raw length: {len(raw_response)})")

    # 1. Pre-process and Clean
    code = clean_code(raw_response)
    if not code or len(code) < 15:
        logger.warning(f"[JOB {job_id}] REWARD: -1.0 | REASON: No valid code blocks extracted.")
        return VerificationResponse(
            reward=-1.0, 
            log="Format Error: Empty or invalid code block.",
            metrics={"total_time": time.time() - full_start_time}
        )

    # 2. Workspace Setup (Sandbox)
    work_dir = Path("/tmp") / f"go_job_{job_id}_{int(time.time())}"
    work_dir.mkdir(parents=True, exist_ok=True)
    
    try:
        # File Preparation
        (work_dir / "main.go").write_text(code)
        if test_code:
            if "package " not in test_code:
                test_code = "package main\n\n" + test_code
            (work_dir / "main_test.go").write_text(test_code)

        # A. Module Setup
        await run_command(["go", "mod", "init", f"verify/job_{job_id}"], cwd=work_dir)
        
        # B. Compilation Phase
        logger.info(f"[JOB {job_id}] Compiling Go code...")
        exit_code, stdout, stderr, build_time = await run_command(["go", "build", "."], cwd=work_dir)
        
        if exit_code != 0:
            logger.info(f"[JOB {job_id}] REWARD: 0.1 | REASON: Compilation Failed | TIME: {build_time:.2f}s")
            return VerificationResponse(
                reward=0.1, 
                log=f"Compilation Error: {stderr or stdout}",
                metrics={"build_time": build_time, "total_time": time.time() - full_start_time}
            )

        # C. Test Execution Phase
        logger.info(f"[JOB {job_id}] Compilation successful. Running test suite...")
        t_exit, t_stdout, t_stderr, t_time = await run_command(["go", "test", "-v", "."], cwd=work_dir)
        
        total_time = time.time() - full_start_time
        metrics = {"build_time": build_time, "test_time": t_time, "total_time": total_time}

        if t_exit == 0:
            logger.info(f"[JOB {job_id}] REWARD: 1.0 | REASON: Success | EXEC: {t_time:.2f}s | TOTAL: {total_time:.2f}s")
            return VerificationResponse(reward=1.0, log="Success: All tests passed.", metrics=metrics)
        
        elif t_exit == 124:
            logger.warning(f"[JOB {job_id}] REWARD: 0.0 | REASON: Watchdog Timeout | EXEC: {t_time:.2f}s")
            return VerificationResponse(reward=0.0, log="Error: Execution timed out (possible infinite loop).", metrics=metrics)
        
        else:
            logger.info(f"[JOB {job_id}] REWARD: 0.3 | REASON: Test Failures | EXEC: {t_time:.2f}s")
            return VerificationResponse(
                reward=0.3, 
                log=f"Logic Error: Test failures detected.\n{t_stdout or t_stderr}", 
                metrics=metrics
            )

    except Exception as e:
        logger.error(f"[JOB {job_id}] CRITICAL ERROR: {str(e)}", exc_info=True)
        return VerificationResponse(
            reward=0.0, 
            log=f"Internal server error: {str(e)}",
            metrics={"total_time": time.time() - full_start_time}
        )

    finally:
        # 3. Final Sandbox Cleanup
        if work_dir.exists():
            shutil.rmtree(work_dir, ignore_errors=True)

# ==============================================================================
# 5. SERVER RUNNER
# ==============================================================================

if __name__ == "__main__":
    # Host 0.0.0.0 is mandatory for Kubernetes pods and Docker communication
    uvicorn.run(app, host="0.0.0.0", port=8000)