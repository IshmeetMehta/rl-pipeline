import os
import subprocess
import uuid
from fastapi import FastAPI, Body

app = FastAPI()

def run_command(command, cwd):
    try:
        result = subprocess.run(
            command, cwd=cwd, capture_output=True, text=True, timeout=10
        )
        return result.returncode, result.stdout, result.stderr
    except subprocess.TimeoutExpired:
        return 124, "", "Timeout"

@app.post("/verify")
async def verify_code(payload: dict = Body(...)):
    # Extract data from NeMo RL payload
    code = payload.get("completion", "")
    # Metadata contains the hidden unit tests the model must pass
    extra_info = payload.get("extra_env_info", {})
    test_code = extra_info.get("test_code", "")
    
    # Unique workspace for this request
    job_id = str(uuid.uuid4())
    work_dir = f"/tmp/{job_id}"
    os.makedirs(work_dir, exist_ok=True)
    
    try:
        # 1. Write Go files
        with open(f"{work_dir}/main.go", "w") as f:
            f.write(code)
        with open(f"{work_dir}/main_test.go", "w") as f:
            f.write(test_code)
        
        # 2. Initialize Go module (needed for modern Go)
        subprocess.run(["go", "mod", "init", "reward/check"], cwd=work_dir, capture_output=True)

        # 3. Compile Check
        code_exit, _, stderr = run_command(["go", "build", "."], cwd=work_dir)
        if code_exit != 0:
            return {"reward": -1.0, "log": f"Compile Error: {stderr}"}

        # 4. Run Unit Tests
        test_exit, _, stderr = run_command(["go", "test", "-v", "."], cwd=work_dir)
        if test_exit == 0:
            return {"reward": 1.0, "log": "Success"}
        else:
            return {"reward": 0.2, "log": f"Logic Error: {stderr}"} # Partial credit for compiling

    finally:
        # Clean up disk space
        subprocess.run(["rm", "-rf", work_dir])

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)