apiVersion: ray.io/v1
kind: RayCluster
metadata:
  name: nemo-rl-grpo-cluster
  namespace: default
spec:
  rayVersion: '2.40.0'
  
  ##############################################################################
  # HEAD NODE: n2-standard-32 (32 vCPU, 128GB RAM)
  ##############################################################################
  headGroupSpec:
    rayStartParams:
      dashboard-host: '0.0.0.0'
      num-cpus: '0'
    template:
      metadata:
        annotations:
          gke-gcsfuse/volumes: "true"
        labels:
          ray.io/node-type: head
      spec:
        # KEY FIX: Ensure the Pod uses your authorized Service Account
        serviceAccountName: nemo-ksa
        nodeSelector:
          ray.io/node-type: head
        containers:
        - name: ray-head
          image: nvcr.io/nvidia/nemo-rl:v0.5.0
          resources:
            limits:
              cpu: "30"
              memory: "115Gi"
            requests:
              cpu: "28"
              memory: "110Gi"
          volumeMounts:
          - name: gcs-fuse-data
            mountPath: /mount/gcs
          - name: dshm
            mountPath: /dev/shm
        volumes:
        - name: gcs-fuse-data
          csi:
            driver: gcsfuse.csi.storage.gke.io
            volumeAttributes:
              bucketName: "golang-sample-prompts-dataset"
              mountOptions: "implicit-dirs"
        - name: dshm
          emptyDir:
            medium: Memory
            sizeLimit: "60Gi"

  ##############################################################################
  # WORKER NODES: 2x Nodes (g2-standard-24, 2x NVIDIA L4 each)
  ##############################################################################
  workerGroupSpecs:
  - groupName: dual-l4-workers
    replicas: 2
    minReplicas: 2
    maxReplicas: 4
    rayStartParams:
      num-gpus: "2"
    template:
      metadata:
        annotations:
          gke-gcsfuse/volumes: "true"
        labels:
          ray.io/node-type: worker
      spec:
        # KEY FIX: Workers also need the authorized Service Account
        serviceAccountName: nemo-ksa
        nodeSelector:
          cloud.google.com/gke-accelerator: nvidia-l4
        containers:
        - name: ray-worker
          image: nvcr.io/nvidia/nemo-rl:v0.5.0
          resources:
            limits:
              nvidia.com/gpu: 2
              cpu: "22"
              memory: "88Gi"
            requests:
              nvidia.com/gpu: 2
              cpu: "20"
              memory: "80Gi"
          volumeMounts:
          - name: gcs-fuse-data
            mountPath: /mount/gcs
          - name: dshm
            mountPath: /dev/shm
        volumes:
        - name: gcs-fuse-data
          csi:
            driver: gcsfuse.csi.storage.gke.io
            volumeAttributes:
              bucketName: "golang-sample-prompts-dataset"
              mountOptions: "implicit-dirs"
        - name: dshm
          emptyDir:
            medium: Memory
            sizeLimit: "40Gi"