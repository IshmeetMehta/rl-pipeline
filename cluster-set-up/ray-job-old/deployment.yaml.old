apiVersion: ray.io/v1
kind: RayCluster
metadata:
  name: nemo-rl-ray
spec:
  rayVersion: '2.40.0'
  # --- HEAD GROUP CONFIGURATION (UPGRADED) ---
  headGroupSpec:
    rayStartParams:
      dashboard-host: '0.0.0.0'
    template:
      metadata:
        annotations:
          gke-gcsfuse/volumes: "true"
      spec:
        serviceAccountName: nemo-ksa
        tolerations:
        - key: "nvidia.com/gpu"
          operator: "Equal"
          value: "present"
          effect: "NoSchedule"
        containers:
        - name: ray-head
          image: nvcr.io/nvidia/nemo-rl:v0.5.0
          resources:
            limits:
              cpu: "4"        # Increased to handle RPC/GCS load
              memory: "16Gi"  # Increased to prevent OOM during vLLM init
            requests:
              cpu: "2"
              memory: "8Gi"
          volumeMounts:
          - name: gcs-fuse-data
            mountPath: /mount/gcs
        volumes:
        - name: gcs-fuse-data
          csi:
            driver: gcsfuse.csi.storage.gke.io
            volumeAttributes:
              bucketName: "golang-sample-prompts-dataset"
              mountOptions: "implicit-dirs,file-mode=777,dir-mode=777"

  # --- WORKER GROUP CONFIGURATION ---
  workerGroupSpecs:
  - groupName: gpu-group
    replicas: 2
    rayStartParams:
      num-gpus: "1" 
    template:
      metadata:
        annotations:
          gke-gcsfuse/volumes: "true"
      spec:
        serviceAccountName: nemo-ksa
        tolerations:
        - key: "nvidia.com/gpu"
          operator: "Equal"
          value: "present"
          effect: "NoSchedule"
        containers:
        - name: ray-worker
          image: nvcr.io/nvidia/nemo-rl:v0.5.0
          resources:
            limits:
              nvidia.com/gpu: 1
              cpu: "8"
              memory: "32Gi"
            requests:
              nvidia.com/gpu: 1
              cpu: "4"
              memory: "12Gi"
          volumeMounts:
          - name: gcs-fuse-data
            mountPath: /mount/gcs
        volumes:
        - name: gcs-fuse-data
          csi:
            driver: gcsfuse.csi.storage.gke.io
            volumeAttributes:
              bucketName: "golang-sample-prompts-dataset"
              mountOptions: "implicit-dirs,file-mode=777,dir-mode=777"