# ==============================================================================
# NeMo RL GRPO - FINAL PRODUCTION CONFIG (Verified for Go Reward Server)
# ==============================================================================

# 1. Experiments & Tracking
logger:
  log_dir: /mount/gcs/logs/nemo_grpo_golang_final
  num_val_samples_to_print: 5
  tensorboard_enabled: true
  save_interval: 1              # Flush logs every 1 step
  update_interval: 1            # Update metrics every 1 step
  wandb_enabled: false
  swanlab_enabled: false
  mlflow_enabled: false
  monitor_gpus: true
  tensorboard: {}
  wandb: {}
  swanlab: {}
  mlflow: {}
  gpu_monitoring:
    collection_interval: 10
    flush_interval: 10

# 2. Weights & Metrics
checkpointing:
  enabled: true
  save_period: 500 
  checkpoint_dir: "/mount/gcs/checkpoints"
  metric_name: "train:reward"        # FIXED: Changed from val:reward to match val_period: 0
  keep_top_k: 1
  higher_is_better: true
  checkpoint_must_save_by: "0:0:10:0"
  resume_from_checkpoint: null 
  save_atomic: false                 # REQUIRED for GCS mounts
  save_consolidated: true
  model_save_format: "safetensors"

# 3. Infrastructure
cluster:
  num_nodes: 2
  gpus_per_node: 2
  placement_strategy: "SPREAD"

trainer:
  precision: bf16-mixed
  devices: 2
  num_nodes: 2
  strategy: ddpp
  accelerator: gpu
  gradient_clip_val: 1.0
  gradient_clip_algorithm: norm
  max_steps: 2000
  accumulate_grad_batches: 1

# 4. Dataset & Processor
data:
  env_name: "math"
  processor: "math_data_processor" # FIXED: Correctly extracts Go code for NemoGym
  dataset_name: "ResponseDataset"
  train_data_path: "/mount/gcs/dataset/train.jsonl"
  max_input_seq_length: 2048
  shuffle: true
  num_workers: 1
  prompt_file: null
  system_prompt_file: null

  train:
    - data_path: "/mount/gcs/dataset/train.jsonl"
      dataset_name: "ResponseDataset"
      input_key: "input"
      env_name: "math"
  
  validation:
    - data_path: "/mount/gcs/dataset/val.jsonl"
      dataset_name: "ResponseDataset"
      input_key: "input"
      env_name: "math"

  default:
    dataset_name: "ResponseDataset"
    input_key: "input"
    output_key: "expected_answer"
    extra_env_info_key: "extra_env_info"
    processor: "math_data_processor"
    env_name: "math"
    prompt_file: null
    system_prompt_file: null
    processor_kwargs:
      input_key: "input"

# 5. Remote Reward Service
env:
  math: 
    name: "nemo_gym" 
    base_urls: 
      - "http://go-reward-svc:8000/verify"
    num_workers: 16
    timeout: 30

# 6. Loss Function
loss_fn:
  reference_policy_kl_penalty: 0.02
  reference_policy_kl_type: "k3"
  kl_input_clamp_value: 20.0
  kl_output_clamp_value: 10.0
  ratio_clip_min: 0.8
  ratio_clip_max: 1.2
  ratio_clip_c: null
  use_on_policy_kl_approximation: false
  use_importance_sampling_correction: false
  truncated_importance_sampling_ratio: null
  truncated_importance_sampling_ratio_min: null
  truncated_importance_sampling_type: "tis"
  sequence_level_importance_ratios: false
  token_level_loss: true
  force_on_policy_ratio: false
  use_kl_in_reward: false

# 7. RL Engine Parameters (GRPO)
grpo:
  seed: 42
  num_prompts_per_step: 1
  num_generations_per_prompt: 4
  max_num_steps: 2000
  max_rollout_turns: 1
  max_num_epochs: 1
  normalize_rewards: true
  use_leave_one_out_baseline: true
  use_dynamic_sampling: false
  val_period: 0
  val_at_start: false
  val_at_end: false
  max_val_samples: 2
  val_batch_size: 2
  overlong_filtering: false
  batch_multiplier: 1
  reward_shaping:
    enabled: false
    overlong_buffer_length: 128
    overlong_buffer_penalty: 1
    max_response_length: 4096
    stop_properly_penalty_coef: null 
  adv_estimator:
    name: "grpo"
    args:                            # FIXED: Indentation corrected
      normalize_rewards: true
      use_leave_one_out_baseline: true
  reward_scaling:
    enabled: false
    source_min: 0.0
    source_max: 1.0
    target_min: 0.0
    target_max: 1.0

# 8. Policy & Generation
policy:
  sequential_worker_init: true
  model_name: "/mount/gcs/models" 
  tokenizer:
    name: "/mount/gcs/models"
  precision: "bfloat16"
  max_total_sequence_length: 4096
  logprob_batch_size: 2
  make_sequence_length_divisible_by: 8
  offload_optimizer_for_logprob: false
  mixed_precision: true
  model:
    torch_dtype: bfloat16
  train_micro_batch_size: 2 
  train_global_batch_size: 4
  max_grad_norm: 1.0
  sequence_packing:
    enabled: false
    num_sequences_per_pack: 1
  dynamic_batching:
    enabled: false
    train_mb_tokens: 4096
    logprob_mb_tokens: 4096
    sequence_length_round: 1
  optimizer:
    name: "torch.optim.AdamW"
    kwargs:
      lr: 1e-6
      weight_decay: 0.01
      eps: 1e-8
      betas: [0.9, 0.99]
  scheduler:
    name: "torch.optim.lr_scheduler.CosineAnnealingLR"
    kwargs:
      T_max: 2000
      eta_min: 1e-7
  dtensor_cfg:
    enabled: true
    tensor_parallel_size: 2
    context_parallel_size: 1
    pipeline_parallel_size: 1
    sequence_parallel: false
    cpu_offload: false
    activation_checkpointing: false
    recompute_granularity: null
    _v2: true
    env_vars:
      PYTORCH_CUDA_ALLOC_CONF: "max_split_size_mb:64"
  generation:
    backend: "vllm"
    prompt_template: "<|im_start|>system\nYou are a senior Go developer. Write functional Go code.<|im_end|>\n<|im_start|>user\n{input}<|im_end|>\n<|im_start|>assistant\n"
    max_new_tokens: 1024
    temperature: 0.7 
    top_p: 1.0
    top_k: -1
    stop_token_ids: [151643, 151645]
    stop_strings: null
    colocated:
      enabled: true
    vllm_cfg:
      precision: ${policy.precision}
      tensor_parallel_size: 2
      pipeline_parallel_size: 1
      gpu_memory_utilization: 0.3
      expert_parallel_size: 1
      enforce_eager: false
      async_engine: false
      sequential_worker_init: true
      max_model_len: 4096
      kv_cache_dtype: "auto"
      env_vars:
        NCCL_SOCKET_IFNAME: "eth0"
        NCCL_IB_DISABLE: "1"
        NCCL_DEBUG: "INFO"
        HF_HOME: "/root/.cache/huggingface"
        PYTORCH_CUDA_ALLOC_CONF: "max_split_size_mb:64"
        # --- ADD THESE DEBUG FLAGS ---
        VLLM_LOG_LEVEL: "DEBUG"
        PYTHONUNBUFFERED: "1"
      # These flags specifically print the text to the logs
      extra_kwargs:
        disable_log_requests: false
        enable_log_outputs: true

# 9. Global Inference Backend
model:
  generation:
    backend: "vllm"
    vllm_kwargs:
      dtype: "bfloat16"
      gpu_memory_utilization: 0.3
    max_new_tokens: ${policy.generation.max_new_tokens}
    temperature: 0.7
    kv_cache_dtype: "auto"