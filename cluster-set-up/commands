# # 6. Run the training job

# 1. Identify the Head Pod
HEAD_POD=$(kubectl get pods -l ray.io/node-type=head -o name | head -n 1)

# 2. Execute the Job with Optimized Parallelism
kubectl exec -it $HEAD_POD -- \
    uv run python examples/run_grpo.py \
    --config examples/configs/grpo_math_1B.yaml \
    policy.model_name="Qwen/Qwen2.5-Coder-7B" \
    data.train_data_path="/mount/gcs/train.jsonl" \
    trainer.num_nodes=2 \
    trainer.devices=8 \
    trainer.precision="bf16" \
    policy.tensor_model_parallel_size=2 \
    policy.pipeline_model_parallel_size=1 \
    algorithm.num_rollouts=8 \
    algorithm.reward_fn.type="http" \
    algorithm.reward_fn.url="http://go-reward-svc/verify" \
    exp_manager.name="qwen-golang-rl" \
    checkpointing.checkpoint_dir="/mount/gcs/checkpoints/qwen-7b-grpo"

