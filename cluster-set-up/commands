# New RUNNNNN

1. Create a cluster
# Variables
export CLUSTER_NAME=nemo-rl-ray
export ZONE=us-central1-a
export PROJECT_ID=$(gcloud config get-value project)

# Create Cluster with a robust Head Node (16 vCPU, 64GB RAM)
# Includes GCS Fuse CSI driver for your dataset mounting
gcloud container clusters create $CLUSTER_NAME \
    --zone $ZONE \
    --machine-type n2-standard-16 \
    --num-nodes 1 \
    --addons GcsFuseCsiDriver,RayOperator \
    --workload-pool=$PROJECT_ID.svc.id.goog \
    --logging=SYSTEM,WORKLOAD \
    --monitoring=SYSTEM

2. Create Nodepool for ray head

# Create the Head Node Pool with n2-standard-32 (32 vCPU, 128GB RAM)
gcloud container node-pools create ray-head-pool \
    --cluster $CLUSTER_NAME \
    --zone $ZONE \
    --machine-type n2-standard-32 \
    --num-nodes 1 \
    --node-labels="ray.io/node-type=head" \
    --disk-size 200GB \
    --disk-type pd-ssd \
    --workload-metadata=GKE_METADATA \
    --no-enable-private-nodes

3. Create nodepool for workers

# Create the Multi-GPU Worker Pool (2 GPUs per node, 2 nodes)
gcloud container node-pools create gpu-multi-worker-pool \
    --cluster $CLUSTER_NAME \
    --zone $ZONE \
    --machine-type g2-standard-24 \
    --accelerator "type=nvidia-l4,count=2" \
    --num-nodes 2 \
    --enable-autoscaling --min-nodes 0 --max-nodes 4 \
    --node-labels="ray.io/node-type=worker" \
    --disk-size 200GB \
    --metadata="install-nvidia-driver=true" \
    --no-enable-private-nodes


4. Create gvisor nodepool (reward server)

gcloud container node-pools create sandbox \
    --cluster=nemo-rl-ray \
    --zone=us-central1-a \
    --num-nodes=1 \
    --machine-type=n2-standard-4 \
    --image-type=cos_containerd \
    --sandbox type=gvisor \
    --no-enable-private-nodes

5. Install the kuberay operator

helm repo add kuberay https://ray-project.github.io/kuberay-helm/
helm repo update
# Install both CRDs and KubeRay operator v1.5.1.
helm install kuberay-operator kuberay/kuberay-operator --version 1.5.1

